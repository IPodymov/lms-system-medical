DEBUG=0
DJANGO_SECRET_KEY=replace-with-a-long-random-production-secret
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
ALLOWED_HOSTS=your-app.up.railway.app
CSRF_TRUSTED_ORIGINS=https://your-app.up.railway.app
# Required in production to expose Django admin. Use a long, private path without
# a leading slash, for example: control-4f6d8a92
DJANGO_ADMIN_URL=
# Set only for local test runs; never use in Railway.
DJANGO_USE_SQLITE=0
CELERY_BROKER_URL=redis://redis:6379/0
