DEBUG=0
DJANGO_SECRET_KEY=replace-with-a-long-random-production-secret
# External PostgreSQL connection URL. This value is configured in Vercel, not committed.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DJANGO_USE_SQLITE=0
ALLOWED_HOSTS=.vercel.app,your-domain.example
CSRF_TRUSTED_ORIGINS=https://*.vercel.app,https://your-domain.example
# Required in production to expose Django admin. Use a long, private path without
# a leading slash, for example: control-4f6d8a92
DJANGO_ADMIN_URL=
# Set only for local test runs; never use on Vercel.
DJANGO_USE_SQLITE=0
